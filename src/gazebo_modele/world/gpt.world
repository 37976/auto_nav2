<?xml version="1.0" ?>
<sdf version="1.6">
  <world name="voronoi_test_complex">

    <!-- 基础物理与插件 -->
    <include>
      <uri>model://sun</uri>
    </include>

    <include>
      <uri>model://ground_plane</uri>
    </include>

    <scene>
      <ambient>0.6 0.6 0.6 1</ambient>
      <background>0.8 0.9 1.0 1</background>
      <shadows>false</shadows>
    </scene>

    <physics type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_update_rate>1000</real_time_update_rate>
      <real_time_factor>1</real_time_factor>
    </physics>

    <!-- ===================================================== -->
    <!-- 外边界：整体约 40m x 30m -->
    <!-- ===================================================== -->
    <model name="boundary_north">
      <static>true</static>
      <pose>0 15 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>40 0.5 1</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>40 0.5 1</size></box>
          </geometry>
          <material><ambient>0.7 0.7 0.7 1</ambient></material>
        </visual>
      </link>
    </model>

    <model name="boundary_south">
      <static>true</static>
      <pose>0 -15 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>40 0.5 1</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>40 0.5 1</size></box>
          </geometry>
          <material><ambient>0.7 0.7 0.7 1</ambient></material>
        </visual>
      </link>
    </model>

    <model name="boundary_west">
      <static>true</static>
      <pose>-20 0 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>0.5 30 1</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>0.5 30 1</size></box>
          </geometry>
          <material><ambient>0.7 0.7 0.7 1</ambient></material>
        </visual>
      </link>
    </model>

    <model name="boundary_east">
      <static>true</static>
      <pose>20 0 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>0.5 30 1</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>0.5 30 1</size></box>
          </geometry>
          <material><ambient>0.7 0.7 0.7 1</ambient></material>
        </visual>
      </link>
    </model>

    <!-- ===================================================== -->
    <!-- 主分区墙：制造长走廊、门口、绕行 -->
    <!-- ===================================================== -->
    <model name="wall_h1_left">
      <static>true</static>
      <pose>-11 8 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>16 0.4 1</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>16 0.4 1</size></box></geometry></visual>
      </link>
    </model>

    <model name="wall_h1_right">
      <static>true</static>
      <pose>12.5 8 0.5 0 0 0</pose>
      <link name="link">
