    </model>

    <model name="wall_v1_top">
      <static>true</static>
      <pose>-8 11 0.5 0 0 1.5708</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>8 0.4 1</size></box></geometry></collision>
