    <!-- ===================================================== -->
    <!-- 起点 / 终点可视化标记 -->
    <!-- ===================================================== -->
    <model name="start_marker">
      <static>true</static>
      <pose>-18 -13 0.15 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry><box><size>0.8 0.8 0.3</size></box></geometry>
          <material>
            <ambient>0 1 0 1</ambient>
            <diffuse>0 1 0 1</diffuse>
          </material>
        </visual>
