      <pose>6 12 0.5 0 0 1.5708</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>6 0.4 1</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>6 0.4 1</size></box></geometry></visual>
      </link>
    </model>

    <model name="wall_v2_bottom">
      <static>true</static>
      <pose>6 1.5 0.5 0 0 1.5708</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>11 0.4 1</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>11 0.4 1</size></box></geometry></visual>
