    <!-- 窄通道 / 挤压障碍 -->
    <!-- ===================================================== -->
    <model name="narrow_box_1">
      <static>true</static>
      <pose>-2 -7 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>2.0 2.0 1</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>2.0 2.0 1</size></box></geometry></visual>
