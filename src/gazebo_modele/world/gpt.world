      <static>true</static>
      <pose>-4 11 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>1.5 1.0 1</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>1.5 1.0 1</size></box></geometry></visual>
      </link>
